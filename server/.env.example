# VoiceBridge Server — .env template
# Copy to .env and fill in real values

ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

GROQ_API_KEY=gsk_...

# NOWPayments (crypto payments — https://nowpayments.io)
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
NOWPAYMENTS_IPN_SECRET=your_ipn_secret

# IBAN bank transfer details
IBAN_ACCOUNT_HOLDER=VoiceBridge Ltd
IBAN_NUMBER=TR00 0000 0000 0000 0000 0000 00
IBAN_BIC=XXXXTRXX
IBAN_BANK_NAME=Your Bank

# Server public URL (for payment callbacks)
SERVER_PUBLIC_URL=https://api.voicebridgeapps.com
WEBSITE_URL=https://voicebridgeapps.com

# SQLite path (Railway: /app/data/voicebridge.db)
DATABASE_URL=sqlite+aiosqlite:///./voicebridge.db

# License HMAC signing secret (generate: python -c "import secrets; print(secrets.token_hex(32))")
LICENSE_SECRET=changeme

# CORS — comma-separated origins
CORS_ORIGINS=https://voicebridgeapps.com,http://localhost:3000

# Firebase Admin SDK (paste full service account JSON, single line)
FIREBASE_SERVICE_ACCOUNT_JSON=


