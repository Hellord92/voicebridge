{
  "manifest_version": 3,
  "name": "VoiceBridge",
  "short_name": "VoiceBridge",
  "version": "0.2.0",
  "description": "Real-time voice translation for Google Meet — speak any language, meeting hears another.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "VoiceBridge"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "permissions": [
    "storage",
    "offscreen",
    "tabCapture",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://translate.googleapis.com/*",
    "https://api.voicebridgeapps.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content/content.js"],
      "css": ["content/panel.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected/page-bridge.js"],
      "matches": ["https://meet.google.com/*"]
    }
  ]
}
