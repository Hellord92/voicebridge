# VoiceBridge — Apple Developer ID Signing Config
# Kopyala: cp .env.codesign.example .env.codesign
# .gitignore'da zaten var, commit'lenMEZ.

# Apple ID (developer@email.com)
APPLE_ID=senin@email.com

# Team ID — developer.apple.com/account → Membership → Team ID
# Örnek: AB12CD34EF
APPLE_TEAM_ID=BURAYA_TEAM_ID

# App-specific password — appleid.apple.com → Security → App-Specific Passwords
# Örnek: abcd-efgh-ijkl-mnop
APPLE_APP_PASSWORD=abcd-efgh-ijkl-mnop

# Certificate identity — terminalde: security find-identity -v -p codesigning
# Örnek: Developer ID Application: Sezer Cifci (AB12CD34EF)
DEVELOPER_ID_APP=Developer ID Application: Sezer Cifci (BURAYA_TEAM_ID)
